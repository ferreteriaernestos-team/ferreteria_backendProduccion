{
  "compilerOptions": {
    /* =========================
       CONFIGURACIÓN GENERAL
    ========================== */
    "target": "ES2020",
    "module": "CommonJS",

    /* =========================
       ESTRUCTURA DEL PROYECTO
    ========================== */
   "rootDir": "./",
    "outDir": "./dist",

    /* =========================
       COMPATIBILIDAD NODE
    ========================== */
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* =========================
       SEGURIDAD Y TIPADO
    ========================== */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

   "include": ["./src", "./generated"],
  "exclude": ["node_modules"]
}
